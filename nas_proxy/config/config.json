{
  "log": {
    "access": "/var/log/v2ray/access.log",
    "error": "/var/log/v2ray/error.log",
    "loglevel": "warning"
  },
  "dns": {
    "servers": [
      {
        "address": "223.5.5.5",
        "domains": ["domain:tianditu.gov.cn", "domain:tianditu.cn"]
      },
      {
        "address": "119.29.29.29",
        "domains": ["domain:tianditu.gov.cn", "domain:tianditu.cn"]
      },
      "8.8.8.8"
    ]
  },
  "inbounds": [
    {
      "port": 1080,
      "protocol": "http",
      "settings": {
        "auth": "noauth",
        "udp": true
      }
    },
    {
      "port": 8080,
      "protocol": "http",
      "settings": {
        "allowTransparent": true
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIP"
      },
      "tag": "direct"
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "outboundTag": "china-proxy",
        "domain": ["domain:tianditu.gov.cn", "domain:tianditu.cn"]
      },
      {
        "type": "field",
        "outboundTag": "direct",
        "network": "tcp,udp"
      }
    ]
  }
}
