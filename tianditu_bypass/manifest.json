{
  "manifest_version": 3,
  "name": "Tianditu Hybrid Accelerator",
  "version": "1.8",
  "description": "Fast multi-source proxy failover and session cleaning.",
  "permissions": [
    "proxy",
    "storage",
    "alarms",
    "offscreen",
    "webRequest",
    "cookies",
    "browsingData"
  ],
  "host_permissions": [
    "https://freeproxy.world/*",
    "https://*.freeproxy.world/*",
    "https://databay.com/*",
    "https://*.databay.com/*",
    "*://*.tianditu.gov.cn/*",
    "*://*.tianditu.cn/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Tianditu Accelerator Status"
  },
  "icons": {
    "128": "icon.png"
  }
}
