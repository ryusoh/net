#!/bin/bash

# NAS Build Accelerator: unified 'turbo' wrapper
# ---------------------------------------------
PROJECT_ROOT=$(pwd)
CCACHE_PATH="$PROJECT_ROOT/.ccache"

show_help() {
    echo "NAS Turbo-Charge Tool"
    echo "Usage: ./bin/turbo [command]"
    echo ""
    echo "Commands:"
    echo "  setup    - Initialize C-cache folders"
    echo "  build    - Run high-speed Build (uses ccache)"
    echo "  scrub    - Clean context"
}

setup() {
    echo "[*] Setting up Turbo environment..."
    mkdir -p "$CCACHE_PATH"
    echo "[SUCCESS] Turbo setup complete."
}

build() {
    echo "[*] Launching Turbo Build (High-Speed Native Docker)..."
    mkdir -p "$CCACHE_PATH"
    export DOCKER_BUILDKIT=1
    
    # Use --tmpfs to build in RAM (Speed)
    # Use make -j$(nproc) to use all CPU cores (Speed)
    sudo docker run --rm \
        -v "$PROJECT_ROOT":/app \
        -v "$CCACHE_PATH":/root/.ccache \
        -e CCACHE_DIR=/root/.ccache \
        --tmpfs /tmp:exec,mode=777 \
        ebpf-builder /bin/bash -c "make -C vps_kernel_proxy all -j$(nproc) && make -C nas_proxy all -j$(nproc)"
}

scrub() {
    echo "[*] Scrubbing build context..."
    find . -name ".DS_Store" -delete
    find . -name "__pycache__" -type d -exec rm -rf {} +
    echo "[Done] Context cleaned."
}

case "$1" in
    setup) setup ;;
    build) build ;;
    scrub) scrub ;;
    *) show_help ;;
esac
